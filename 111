                    <p class="mt-6">May you always know how <em>special</em> you are to me and to everyone lucky enough to know you.</p>
                </div>
                <p class="text-3xl lg:text-4xl font-black text-pink-600 mb-12 heart-beat">
                    Happy Birthday, My Alaghi! ❤️
                </p>
                <button class="btn" id="confetti-btn">🎉 ULTIMATE CELEBRATION!</button>
                <div class="mt-12">
                    <button class="btn mr-4" id="replay-btn" style="background: linear-gradient(135deg, #3b82f6, #1d4ed8);">
                        🔄 Replay
                    </button>
                    <button class="btn" id="share-btn" style="background: linear-gradient(135deg, #10b981, #059669);">
                        💝 Share Love
                    </button>
                </div>
                <p class="mt-12 text-xl text-gray-500 font-semibold">Made with ❤️∞ just for you on PC</p>
            </div>
        </div>

        <div id="keyboard-hint">
            ⏎ Press <strong>SPACEBAR</strong> or <strong>ENTER</strong> to continue | <strong>ESC</strong> to restart
        </div>
    </div>

    <script>
        // Enhanced Three.js Heart Background for PC
        const container = document.getElementById('canvas-container');
        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true, powerPreference: "high-performance" });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        container.appendChild(renderer.domElement);

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.z = 35;

        // Enhanced heart geometry
        const heartShape = new THREE.Shape();
        heartShape.moveTo(0.5, 0.5);
        heartShape.bezierCurveTo(0.5, 0.5, 1, 0, 0, 0);
        heartShape.bezierCurveTo(-1, 0, -1, 1.5, -1, 1.5);
        heartShape.bezierCurveTo(-1, 2.5, 0.5, 3.5, 0.5, 3.5);
        heartShape.bezierCurveTo(0.5, 3.5, 2, 2.5, 2, 1.5);
        heartShape.bezierCurveTo(2, 1.5, 2, 0, 1, 0);
        heartShape.bezierCurveTo(0.5, 0, 0.5, 0.5, 0.5, 0.5);

        const extrudeSettings = {
            depth: 0.8,
            bevelEnabled: true,
            bevelSegments: 5,
            bevelSize: 0.3,
            bevelThickness: 0.4
        };

        const heartGeometry = new THREE.ExtrudeGeometry(heartShape, extrudeSettings);

        // More hearts for PC (40 instead of 25)
        const hearts = [];
        const colors = [0xff6b6b, 0xff8e8e, 0xffb3b3, 0xffd8d8, 0xff9e9e, 0xffc1c1, 0xff6b8e, 0xff8eb3, 0xf48fb1, 0xffa8c8];

        for (let i = 0; i < 40; i++) {
            const material = new THREE.MeshPhongMaterial({
                color: colors[Math.floor(Math.random() * colors.length)],
                emissive: 0x440000,
                emissiveIntensity: 0.15,
                shininess: 150,
                transparent: true,
                opacity: 0.85
            });

            const heart = new THREE.Mesh(heartGeometry, material);
            heart.position.x = (Math.random() - 0.5) * 60;
            heart.position.y = (Math.random() - 0.5) * 60;
            heart.position.z = (Math.random() - 0.5) * 60;

            const scale = Math.random() * 1.2 + 0.6;
            heart.scale.set(scale, scale, scale);

            heart.rotation.x = Math.random() * Math.PI;
            heart.rotation.y = Math.random() * Math.PI;
            heart.rotation.z = Math.random() * Math.PI;

            heart.userData = {
                speedX: Math.random() * 0.015 - 0.0075,
                speedY: Math.random() * 0.015 - 0.0075,
                speedZ: Math.random() * 0.015 - 0.0075,
                rotationSpeedX: Math.random() * 0.008,
                rotationSpeedY: Math.random() * 0.008,
                rotationSpeedZ: Math.random() * 0.005,
                originalX: heart.position.x,
                originalY: heart.position.y,
                originalZ: heart.position.z,
                floatDistance: 3 + Math.random() * 4
            };

            scene.add(heart);
            hearts.push(heart);
        }

        // Enhanced lighting
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
        scene.add(ambientLight);

        const directionalLight = new THREE.DirectionalLight(0xffffff, 1);
        directionalLight.position.set(10, 10, 5);
        scene.add(directionalLight);

        const pointLight = new THREE.PointLight(0xff69b4, 0.5, 100);
        pointLight.position.set(0, 20, 10);
        scene.add(pointLight);

        // Mouse interaction
        let mouseX = 0, mouseY = 0;
        document.addEventListener('mousemove', (e) => {
            mouseX = (e.clientX / window.innerWidth) * 2 - 1;
            mouseY = -(e.clientY / window.innerHeight) * 2 + 1;
            camera.position.x = mouseX * 5;
            camera.position.y = mouseY * 5;
            camera.lookAt(0, 0, 0);
        });

        function animate() {
            requestAnimationFrame(animate);
            const time = Date.now() * 0.001;

            hearts.forEach(heart => {
                heart.position.x = heart.userData.originalX + Math.sin(time * heart.userData.speedX * 10) * heart.userData.floatDistance;
                heart.position.y = heart.userData.originalY + Math.sin(time * heart.userData.speedY * 10) * heart.userData.floatDistance;
                heart.position.z = heart.userData.originalZ + Math.sin(time * heart.userData.speedZ * 10) * heart.userData.floatDistance;

                heart.rotation.x += heart.userData.rotationSpeedX;
                heart.rotation.y += heart.userData.rotationSpeedY;
                heart.rotation.z += heart.userData.rotationSpeedZ;

                // Glow pulse
                heart.material.emissiveIntensity = 0.15 + Math.sin(time * 2) * 0.05;
            });

            renderer.render(scene, camera);
        }

        animate();

        // Enhanced resize handler
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        // Step Navigation
        let currentStep = 1;
        const totalSteps = 4;

        function updateProgressBar() {
            const progress = ((currentStep - 1) / (totalSteps - 1)) * 100;
            document.getElementById('progress-bar').style.width = `${progress}%`;
        }

        function showStep(stepNumber) {
            document.querySelectorAll('.step').forEach(step => {
                step.classList.remove('active');
            });
            document.getElementById(`step${stepNumber}`).classList.add('active');
            updateProgressBar();

            if (stepNumber === totalSteps) {('confetti-btn').focus();
            }
        }

        // Button event listeners
        document.getElementById('start-btn').addEventListener('click', () => {
            currentStep = 2;
            showStep(currentStep);
        });

        document.getElementById('next-btn-2').addEventListener('click', () => {
            currentStep = 3;
            showStep(currentStep);
        });

        document.getElementById('next-btn-3').addEventListener('click', () => {
            currentStep = 4;
            showStep(currentStep);
        });

        // ULTIMATE PC CELEBRATION
        document.getElementById('confetti-btn').addEventListener('click', celebrate);

        function celebrate() {
            const btn = document.getElementById('confetti-btn');
            btn.textContent = '🎉 CELEBRATING! 🎉';
            btn.disabled = true;
            btn.style.transform = 'scale(0.95)';

            // MASSIVE EXPLOSION
            for(let i = 0; i < 5; i++) {
                setTimeout(() => {
                    confetti({
                        particleCount: 300,
                        spread: 120,
                        origin: { y: 0.6 },
                        colors: ['#ff6b6b', '#feca57', '#ff9ff3', '#54a0ff', '#5f27cd', '#00d2d3', '#ff4081'],
                        shapes: ['circle', 'square', 'star']
                    });
                }, i * 200);
            }

            // HEART TSUNAMI
            setTimeout(() => {
                for(let i = 0; i < 10; i++) {
                    setTimeout(() => {
                        confetti({
                            particleCount: 50,
                            angle: 90,
                            spread: 70,
                            origin: { x: 0.5, y: 0.1 },
                            colors: ['#ff1744', '#f50057', '#ff4081', '#f8bbd9', '#ffcdd2']
                        });
                    }, i * 100);
                }
            }, 1000);

            // 3D HEARTS EXPLOSION
            hearts.forEach((heart, index) => {
                gsap.to(heart.position, {
                    y: heart.position.y + 50,
                    x: heart.position.x + (Math.random() - 0.5) * 40,
                    z: heart.position.z - 30,
                    duration: 5 + Math.random() * 3,
                    ease: "power2.out",
                    delay: index * 0.03
                });

                gsap.to(heart.rotation, {
                    z: heart.rotation.z + Math.PI * 6,
                    duration: 5,
                    ease: "power2.out"
                });

                gsap.to(heart.material, {
                    opacity: 0,
                    scale: 2.5,
                    emissiveIntensity: 1,
                    duration: 5,
                    ease: "power2.out",
                    delay: index * 0.03,
                    onComplete: () => { heart.visible = false; }
                });
            });

            // Screen shake + camera shake
            document.getElementById('content').style.animation = 'shake 1s ease-in-out';
            gsap.to(camera.position, {
                x: "+=10",
                y: "+=10",
                duration: 0.1,
                yoyo: true,
                repeat: 10
            });

            setTimeout(() => {
                document.getElementById('content').style.animation = '';
                hearts.forEach((heart, index) => {
                    heart.visible = true;
                    heart.material.opacity = 0.85;
                    heart.material.emissiveIntensity = 0.15;
                    heart.scale.set(1, 1, 1);
                    heart.position.set(
                        (Math.random() - 0.5) * 60,
                        (Math.random() - 0.5) * 60,
                        (Math.random() - 0.5) * 60
                    );
                    heart.rotation.set(
                        Math.random() * Math.PI * 2,
                        Math.random() * Math.PI * 2,
                        Math.random() * Math.PI * 2
                    );
                });
                btn.textContent = '🎉 Celebrate Again!';
                btn.disabled = false;
                btn.style.transform = 'scale(1)';
                btn.focus();
            }, 7000);
        }

        // Replay button
        document.getElementById('replay-btn').addEventListener('click', () => {
            currentStep = 1;
            showStep(currentStep);
        });

        // Share button
        document.getElementById('share-btn').addEventListener('click', () => {
            if (navigator.share) {
                navigator.share({
                    title: 'Happy Birthday from someone special! 💖',
                    text: 'Check out this amazing PC birthday experience!',
                    url: window.location.href
                });
            } else {
                navigator.clipboard.writeText(window.location.href).then(() => {
                    confetti({ particleCount: 50, spread: 50 });
                    alert('🎉 Link copied to clipboard! Share the love 💝');
                });
            }
        });

        // PC KEYBOARD NAVIGATION ⭐
        document.addEventListener('keydown', (e) => {
            if (e.code === 'Space' || e.code === 'Enter') {
                e.preventDefault();
                if (currentStep === 1) document.getElementById('start-btn').click();
                else if (currentStep === 2) document.getElementById('next-btn-2').click();
                else if (currentStep === 3) document.getElementById('next-btn-3').click();
                else if (currentStep === 4) celebrate();
            }
            if (e.code === 'Escape') {
                currentStep = 1;
                showStep(currentStep);
            }
        });

        // Show keyboard hint after 2 seconds
        setTimeout(() => {
            document.getElementById('keyboard-hint').classList.add('show');
        }, 2000);

        // Auto-focus first button
        document.getElementById('start-btn').focus();

        // Initialize
        updateProgressBar();
    </script>

    <style>
        @keyframes shake {
            0%, 100% { transform: translateX(0) translateY(0); }
            10%, 30%, 50%, 70%, 90% { transform: translateX(-8px) translateY(-8px); }
            20%, 40%, 60%, 80% { transform: translateX(8px) translateY(8px); }
        }
    </style>
</body>
</html>
